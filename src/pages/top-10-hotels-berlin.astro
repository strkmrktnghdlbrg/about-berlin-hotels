---
import BaseLayout from "../layouts/BaseLayout.astro";
import { hotels, getFeaturedHotels } from "../data/hotels";
import { getDistrict } from "../data/districts";
import { site } from "../data/site";
import HotelCard from "../components/HotelCard.astro";
import JsonLd from "../components/JsonLd.astro";

const locale = "de" as const;

// Top-10-Auswahl: featured + Stars-DESC + Preis-Mix für Diversity.
const featured = getFeaturedHotels();
const others = hotels
  .filter((h) => !h.featured)
  .sort((a, b) => b.stars - a.stars || a.priceFrom - b.priceFrom);
const top10 = [...featured, ...others].slice(0, 10);

const pageUrl = new URL(Astro.url.pathname, site.baseUrl).toString();

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Top 10 Hotels in Berlin",
  itemListOrder: "https://schema.org/ItemListOrderAscending",
  numberOfItems: top10.length,
  itemListElement: top10.map((h, i) => {
    const d = getDistrict(h.district);
    return {
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Hotel",
        name: h.name,
        url: new URL(`/hotels/${h.slug}/`, site.baseUrl).toString(),
        starRating: { "@type": "Rating", ratingValue: h.stars, bestRating: 5 },
        priceRange: `from EUR ${h.priceFrom}`,
        ...(h.website ? { sameAs: [h.website] } : {}),
        ...(d
          ? {
              address: {
                "@type": "PostalAddress",
                addressLocality: d.name,
                addressRegion: "Berlin",
                addressCountry: "DE",
              },
            }
          : {}),
      },
    };
  }),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Start", item: site.baseUrl + "/" },
    { "@type": "ListItem", position: 2, name: "Top 10 Hotels Berlin", item: pageUrl },
  ],
};
---

<BaseLayout
  title="Top 10 Hotels in Berlin 2026 — Luxus, Boutique & Lifestyle im Überblick"
  description="Die zehn besten Hotels in Berlin nach Lage, Stil und Preis-Leistung. Vom Adlon am Brandenburger Tor bis zum Designhotel in Friedrichshain — kuratiert und ehrlich beschrieben."
  locale={locale}
>
  <JsonLd data={itemListSchema} />
  <JsonLd data={breadcrumbSchema} />

  <section class="relative overflow-hidden gradient-spree text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-20">
      <nav class="flex items-center gap-2 text-xs text-white/80 mb-6 flex-wrap">
        <a href="/" class="hover:text-white">Start</a>
        <span>›</span>
        <span class="text-white">Top 10 Hotels Berlin</span>
      </nav>

      <span class="inline-flex items-center gap-2 rounded-full bg-white/15 backdrop-blur-sm border border-white/20 px-3 py-1 text-[11px] font-bold uppercase tracking-widest mb-5">
        Redaktionelle Auswahl · 2026
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-balance mb-6 leading-[1.05]">
        Die 10 besten Hotels in Berlin
      </h1>
      <p class="text-lg sm:text-xl text-brand-50/95 leading-relaxed max-w-3xl text-balance">
        Quer durch Bezirke und Preisklassen — vom Adlon am Brandenburger Tor bis zum
        kreativen Boutiquehotel in Friedrichshain. Jede Empfehlung mit Bezirks-Lage,
        Ausstattung und ehrlicher Beschreibung.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <ol class="space-y-8">
        {top10.map((h, i) => (
          <li class="grid gap-4 sm:grid-cols-[80px_1fr] items-start">
            <div class="flex sm:flex-col items-center sm:items-start gap-2 sm:gap-1">
              <span class="text-5xl font-bold text-brand-700 leading-none">#{i + 1}</span>
            </div>
            <HotelCard hotel={h} locale={locale} />
          </li>
        ))}
      </ol>

      <div class="mt-12 rounded-2xl border border-ink-100 bg-ink-50 p-6">
        <p class="text-sm text-ink-700 leading-relaxed">
          <strong class="text-ink-900">Wie wir auswählen.</strong> Diese Top 10 basiert auf
          Lage (Bezirks-Wahl), Ausstattung, Berliner Geschichte des Hauses und
          Preis-Leistung. Affiliate-Provisionen beeinflussen die Reihenfolge nicht —
          wir verdienen nur dann eine Provision, wenn du über einen unserer Booking-Links
          buchst, ohne Aufpreis für dich.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
