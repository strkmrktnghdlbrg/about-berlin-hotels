---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import DistrictPage from "../../../components/DistrictPage.astro";
import { districts } from "../../../data/districts";

export async function getStaticPaths() {
  return districts.map((d) => ({ params: { slug: d.slug }, props: { district: d } }));
}

const { district } = Astro.props;
const title = `Hotels in ${district.name} - About Berlin Hotels`;
const description = district.intro.en.slice(0, 155);
---

<BaseLayout
  title={title}
  description={description}
  locale="en"
  alternatePath={`/stadtteile/${district.slug}/`}
>
  <DistrictPage district={district} locale="en" />
</BaseLayout>
