---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import GuidePage from "../../../components/GuidePage.astro";
import { guides } from "../../../data/guides";

export function getStaticPaths() {
  return guides.map((g) => ({ params: { slug: g.slugEn }, props: { guide: g } }));
}

const { guide } = Astro.props;
const locale = "en" as const;
const title = `${guide.title.en} - Berlin itinerary`;
---

<BaseLayout
  title={title}
  description={guide.description.en}
  locale={locale}
  alternatePath={`/reiseplaner/${guide.slug}/`}
>
  <GuidePage guide={guide} locale={locale} />
</BaseLayout>
