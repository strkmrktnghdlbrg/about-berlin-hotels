---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AttractionPage from "../../../components/AttractionPage.astro";
import { attractions } from "../../../data/attractions";

export async function getStaticPaths() {
  return attractions.map((a) => ({ params: { slug: a.slug }, props: { attraction: a } }));
}

const { attraction } = Astro.props;
const title = `${attraction.name.en} — Attraction & Hotels Nearby`;
const description = attraction.intro.en.slice(0, 155);
---

<BaseLayout
  title={title}
  description={description}
  locale="en"
  alternatePath={`/sehenswuerdigkeiten/${attraction.slug}/`}
>
  <AttractionPage attraction={attraction} locale="en" />
</BaseLayout>
