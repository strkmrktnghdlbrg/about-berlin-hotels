---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuidePage from "../../components/GuidePage.astro";
import { guides } from "../../data/guides";

export function getStaticPaths() {
  return guides.map((g) => ({ params: { slug: g.slug }, props: { guide: g } }));
}

const { guide } = Astro.props;
const locale = "de" as const;
const title = `${guide.title.de} - Berliner Reiseplaner`;
---

<BaseLayout
  title={title}
  description={guide.description.de}
  locale={locale}
  alternatePath={`/en/itineraries/${guide.slugEn}/`}
>
  <GuidePage guide={guide} locale={locale} />
</BaseLayout>
