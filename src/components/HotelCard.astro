---
import type { Hotel } from "../data/hotels";
import type { Locale } from "../data/site";
import { getDistrict } from "../data/districts";

type Props = { hotel: Hotel; locale: Locale };
const { hotel, locale } = Astro.props;
const district = getDistrict(hotel.district);
const base = locale === "de" ? "/hotels" : "/en/hotels";
const href = `${base}/${hotel.slug}/`;
---

<a
  href={href}
  class="group block rounded-2xl border border-ink-100 bg-white overflow-hidden transition-all hover:border-brand-200 hover:shadow-lg hover:-translate-y-0.5"
>
  <div class="relative h-44 bg-gradient-to-br from-brand-700 via-brand-500 to-brand-400 flex items-center justify-center text-white">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="h-14 w-14 opacity-40">
      <path d="M3 21V10l9-7 9 7v11" />
      <path d="M9 21V13h6v8" />
      <path d="M3 21h18" />
    </svg>
    <div class="absolute top-3 left-3 flex gap-1.5">
      <span class="inline-flex items-center gap-1 rounded-full bg-white/95 px-2 py-0.5 text-[10px] font-bold text-brand-700">
        {"★".repeat(hotel.stars)}
      </span>
    </div>
    <div class="absolute bottom-3 left-3 text-white">
      <span class="block text-[10px] uppercase tracking-widest opacity-80">
        {district?.name}
      </span>
    </div>
  </div>

  <div class="p-5">
    <h3 class="text-base font-bold text-ink-900 mb-1 group-hover:text-brand-700 transition-colors">
      {hotel.name}
    </h3>
    <p class="text-sm text-ink-600 line-clamp-2 leading-relaxed mb-3">
      {hotel.shortDesc[locale]}
    </p>
    <div class="flex items-center justify-between pt-3 border-t border-ink-100">
      <span class="text-xs text-ink-500">
        {locale === "de" ? "ab" : "from"}
      </span>
      <span class="text-lg font-bold text-brand-700">
        €{hotel.priceFrom}<span class="text-xs font-medium text-ink-500">/{locale === "de" ? "Nacht" : "night"}</span>
      </span>
    </div>
  </div>
</a>
