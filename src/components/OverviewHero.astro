---
import type { Locale } from "../data/site";

type Props = {
  eyebrow: { de: string; en: string };
  title: { de: string; en: string };
  subtitle: { de: string; en: string };
  locale: Locale;
  variant?: "default" | "soft";
};

const { eyebrow, title, subtitle, locale, variant = "default" } = Astro.props;
---

{variant === "default" ? (
  <section class="relative overflow-hidden gradient-spree text-white">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <svg class="absolute -right-20 -top-20 h-96 w-96" viewBox="0 0 200 200">
        <pattern id="grid-ov" width="20" height="20" patternUnits="userSpaceOnUse">
          <path d="M 20 0 L 0 0 0 20" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
        <rect width="200" height="200" fill="url(#grid-ov)"/>
      </svg>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-20">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/15 backdrop-blur-sm border border-white/20 px-3 py-1 text-[11px] font-bold text-white uppercase tracking-widest mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-200"></span>
        {eyebrow[locale]}
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-balance mb-5 leading-[1.05] max-w-4xl">
        {title[locale]}
      </h1>
      <p class="text-lg sm:text-xl text-brand-50/95 leading-relaxed max-w-3xl text-balance">
        {subtitle[locale]}
      </p>
    </div>
  </section>
) : (
  <section class="surface-soft border-b border-ink-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-16">
      <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-2 block">
        {eyebrow[locale]}
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-balance text-ink-900 mb-4 leading-[1.05] max-w-4xl">
        {title[locale]}
      </h1>
      <p class="text-lg sm:text-xl text-ink-700 leading-relaxed max-w-3xl text-balance">
        {subtitle[locale]}
      </p>
    </div>
  </section>
)}
