---
/**
 * ArticlePage — Template für die zurückgeführten WP-Artikel (DE).
 * Rendert einen Article aus src/data/articles.ts mit Hero, Hotel-Karten,
 * Stay22-Karte, Frage-Sektionen, GetYourGuide-Touren, FAQ, internen Links
 * und Article/FAQPage/BreadcrumbList-JSON-LD.
 */
import type { Article } from "../data/articles";
import { getHotel } from "../data/hotels";
import { getDistrict } from "../data/districts";
import { getCategory } from "../data/categories";
import { site } from "../data/site";
import HotelCard from "./HotelCard.astro";
import Stay22Map from "./Stay22Map.astro";
import GetYourGuideWidget from "./GetYourGuideWidget.astro";
import JsonLd from "./JsonLd.astro";

type Props = { article: Article };
const { article } = Astro.props;
const locale = "de" as const;

const district = article.districtSlug ? getDistrict(article.districtSlug) : undefined;
const category = article.categorySlug ? getCategory(article.categorySlug) : undefined;
const featuredHotels = article.hotels.map(getHotel).filter(Boolean);
const url = new URL(`/${article.slug}/`, site.baseUrl).toString();

// Breadcrumb: for theme articles (no district) with a categorySlug, insert category as step 2
const breadcrumbItems: { position: number; name: string; item: string }[] = [
  { position: 1, name: "Start", item: site.baseUrl + "/" },
];
if (district) {
  breadcrumbItems.push({ position: 2, name: district.name, item: new URL(`/stadtteile/${district.slug}/`, site.baseUrl).toString() });
  breadcrumbItems.push({ position: 3, name: article.title, item: url });
} else if (category) {
  breadcrumbItems.push({ position: 2, name: category.name.de, item: new URL(`/kategorien/${category.slug}/`, site.baseUrl).toString() });
  breadcrumbItems.push({ position: 3, name: article.title, item: url });
} else {
  breadcrumbItems.push({ position: 2, name: article.title, item: url });
}

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((i) => ({ "@type": "ListItem", ...i })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.description,
  inLanguage: "de-DE",
  mainEntityOfPage: url,
  datePublished: article.datePublished,
  dateModified: article.dateModified,
  author: { "@type": "Organization", name: site.brand.name, url: site.baseUrl },
  publisher: { "@type": "Organization", name: site.brand.name, url: site.baseUrl },
};

const faqSchema =
  article.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: article.faq.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: { "@type": "Answer", text: f.a },
        })),
      }
    : null;
---

<JsonLd data={breadcrumb} />
<JsonLd data={articleSchema} />
{faqSchema && <JsonLd data={faqSchema} />}

<!-- HERO -->
<section class="relative overflow-hidden surface-soft border-b border-ink-100">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-12 sm:py-16">
    <nav class="flex items-center gap-2 text-xs text-ink-500 mb-6">
      <a href="/" class="hover:text-brand-700">Start</a>
      <span>›</span>
      {district ? (
        <>
          <a href={`/stadtteile/${district.slug}/`} class="hover:text-brand-700">{district.name}</a>
          <span>›</span>
        </>
      ) : category ? (
        <>
          <a href={`/kategorien/${category.slug}/`} class="hover:text-brand-700">{category.name.de}</a>
          <span>›</span>
        </>
      ) : null}
      <span class="text-ink-700">{article.title}</span>
    </nav>

    <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-3 block">
      {article.kicker}
    </span>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-ink-900 text-balance mb-6 leading-[1.1]">
      {article.title}
    </h1>
    <div class="space-y-4 text-lg text-ink-700 leading-relaxed">
      {article.intro.map((p) => <p set:html={p} />)}
    </div>

    {article.bestFor && article.bestFor.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        {article.bestFor.map((b) => (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 border border-brand-100 px-3 py-1 text-xs font-semibold text-brand-700">
            {b}
          </span>
        ))}
      </div>
    )}
  </div>
</section>

<article class="mx-auto max-w-4xl px-4 sm:px-6 py-12 sm:py-16">
  <!-- TAKEAWAYS (TL;DR) -->
  {article.takeaways && article.takeaways.length > 0 && (
    <div class="rounded-2xl border border-brand-100 bg-brand-50 p-6 sm:p-8 mb-12">
      <h2 class="text-lg font-bold text-ink-900 mb-4">Das Wichtigste in Kürze</h2>
      <ul class="space-y-2.5">
        {article.takeaways.map((t) => (
          <li class="flex items-start gap-2.5 text-ink-700">
            <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-600 text-white text-xs font-bold">✓</span>
            <span set:html={t} />
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- FEATURED HOTELS -->
  {featuredHotels.length > 0 && (
    <section class="mb-14">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink-900 mb-2">
        Unsere Hotel-Empfehlungen
      </h2>
      <p class="text-ink-600 leading-relaxed mb-8">
        Handverlesene, verifizierte Häuser aus unserer Redaktion - Live-Preise und Verfügbarkeit über die Karte und Booking.com.
      </p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {featuredHotels.map((h) => <HotelCard hotel={h!} locale={locale} />)}
      </div>
    </section>
  )}

  <!-- STAY22 MAP — Bezirks-Karte, sonst Berlin-weit -->
  <section class="mb-14">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink-900 mb-2">
      {district ? `Hotels in ${district.name} auf der Karte` : "Hotels in Berlin auf der Karte"}
    </h2>
    <p class="text-ink-600 leading-relaxed mb-6">
      Verfügbarkeit und Preise live von Booking.com - vergleiche Lagen, bevor du buchst.
    </p>
    <Stay22Map
      embedId={district?.stay22Id}
      lat={district ? district.geo.lat : 52.52}
      lng={district ? district.geo.lng : 13.405}
      zoom={district ? district.geo.zoom : 12}
      height="560px"
      title={district ? `Hotels in ${district.name}` : "Hotels in Berlin"}
    />
  </section>

  <!-- SECTIONS -->
  <div class="space-y-12">
    {article.sections.map((s) => (
      <section>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink-900 mb-4 text-balance">
          {s.heading}
        </h2>
        <div class="space-y-4 text-ink-700 leading-relaxed">
          {s.body.map((p) => <p set:html={p} />)}
        </div>
        {s.bullets && s.bullets.length > 0 && (
          <ul class="mt-4 space-y-2.5">
            {s.bullets.map((b) => (
              <li class="flex items-start gap-2.5 text-ink-700">
                <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-brand-500"></span>
                <span set:html={b} />
              </li>
            ))}
          </ul>
        )}
        {s.hotels && s.hotels.length > 0 && (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mt-6">
            {s.hotels.map(getHotel).filter(Boolean).map((h) => <HotelCard hotel={h!} locale={locale} />)}
          </div>
        )}
      </section>
    ))}
  </div>

  <!-- GETYOURGUIDE TOURS -->
  {article.gygQuery && (
    <GetYourGuideWidget
      mode="activities"
      q={article.gygQuery}
      numberOfItems={3}
      cmp={`article-${article.slug}`}
      title="Touren & Tickets passend zu deinem Aufenthalt"
      lead="Beliebte Erlebnisse in Berlin - direkt buchbar über GetYourGuide."
      locale={locale}
    />
  )}

  <!-- FAQ -->
  {article.faq.length > 0 && (
    <section class="mt-14">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink-900 mb-6">
        Häufig gestellte Fragen
      </h2>
      <div class="space-y-3">
        {article.faq.map((f) => (
          <details class="group rounded-2xl border border-ink-100 bg-white p-5 sm:p-6 [&_summary]:cursor-pointer">
            <summary class="flex items-center justify-between gap-4 font-semibold text-ink-900 list-none">
              <span>{f.q}</span>
              <span class="text-brand-600 transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <p class="mt-3 text-ink-700 leading-relaxed" set:html={f.a} />
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- CATEGORY HUB LINK -->
  {category && (
    <div class="mt-14 rounded-2xl border border-brand-100 bg-brand-50 p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-1 block">Mehr entdecken</span>
        <p class="text-ink-900 font-semibold text-lg">
          Alle {category.name.de} in Berlin
        </p>
        <p class="text-ink-600 text-sm mt-1">{category.intro.de}</p>
      </div>
      <a
        href={`/kategorien/${category.slug}/`}
        class="inline-flex shrink-0 items-center gap-2 rounded-xl bg-brand-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-brand-800 transition-colors"
      >
        {category.name.de} ansehen →
      </a>
    </div>
  )}

  <!-- RELATED + ADJACENT -->
  <section class="mt-14 grid gap-8 md:grid-cols-2">
    {article.related.length > 0 && (
      <div class="rounded-2xl border border-ink-100 bg-white p-6 sm:p-8">
        <h2 class="text-lg font-bold text-ink-900 mb-4">Passend weiterlesen</h2>
        <ul class="space-y-2.5">
          {article.related.map((l) => (
            <li>
              <a href={l.href} class="inline-flex items-center gap-1.5 text-brand-700 font-medium hover:text-brand-800 hover:underline">
                <span class="text-brand-400">→</span>{l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
    {article.adjacent && article.adjacent.length > 0 && (
      <div class="rounded-2xl border border-brand-100 bg-brand-50 p-6 sm:p-8">
        <h2 class="text-lg font-bold text-ink-900 mb-4">Das fragen Reisende als Nächstes</h2>
        <ul class="space-y-2.5">
          {article.adjacent.map((l) => (
            <li>
              <a href={l.href} class="inline-flex items-start gap-1.5 text-ink-700 font-medium hover:text-brand-700 hover:underline">
                <span class="text-brand-400 mt-0.5">?</span>{l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>

  <p class="mt-10 text-xs text-ink-400">
    Zuletzt aktualisiert: {new Intl.DateTimeFormat("de-DE", { year: "numeric", month: "long" }).format(new Date(article.dateModified))}.
    Hotelangaben redaktionell geprüft; Preise &amp; Verfügbarkeit ändern sich täglich.
  </p>
</article>
