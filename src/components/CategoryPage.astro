---
import type { Category } from "../data/categories";
import type { Locale } from "../data/site";
import { categories } from "../data/categories";
import { getHotelsByCategory } from "../data/hotels";
import { getDistrict, districts } from "../data/districts";
import { articles } from "../data/articles";
import HotelCard from "./HotelCard.astro";
import DistrictCard from "./DistrictCard.astro";
import CategoryCard from "./CategoryCard.astro";
import JsonLd from "./JsonLd.astro";
import { site } from "../data/site";

type Props = { category: Category; locale: Locale };
const { category, locale } = Astro.props;
const base = locale === "de" ? "" : "/en";

const hotelsInCategory = getHotelsByCategory(category.slug);
const bestDistricts = category.bestDistricts
  .map((s) => getDistrict(s))
  .filter((d): d is NonNullable<typeof d> => Boolean(d));

const otherCategories = categories.filter((c) => c.slug !== category.slug).slice(0, 3);

const relatedArticles = articles
  .filter((a) => a.categorySlug === category.slug)
  .slice(0, 6);

const colorMap: Record<Category["color"], string> = {
  navy: "from-brand-800 to-brand-600",
  azure: "from-brand-600 to-brand-400",
  teal: "from-accent-teal to-brand-500",
  indigo: "from-brand-700 to-brand-500",
  sky: "from-brand-500 to-brand-300",
  amber: "from-accent-amber to-brand-400",
};

// --- Structured data (CollectionPage + ItemList + BreadcrumbList) ---
const categoryUrl = new URL(Astro.url.pathname, site.baseUrl).toString();
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locale === "de" ? `${category.name.de} in Berlin` : `${category.name.en} in Berlin`,
  description: category.intro[locale],
  url: categoryUrl,
  inLanguage: locale === "de" ? "de-DE" : "en-US",
  about: { "@type": "Thing", name: category.name[locale] },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: hotelsInCategory.map((h, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: h.name,
      url: new URL(`${base}/hotels/${h.slug}/`, site.baseUrl).toString(),
    })),
  },
};
const categoryBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: locale === "de" ? "Start" : "Home", item: new URL(`${base}/`, site.baseUrl).toString() },
    { "@type": "ListItem", position: 2, name: locale === "de" ? "Kategorien" : "Categories", item: new URL(`${base}/kategorien/`, site.baseUrl).toString() },
    { "@type": "ListItem", position: 3, name: category.name[locale], item: categoryUrl },
  ],
};
---

<JsonLd data={collectionSchema} />
<JsonLd data={categoryBreadcrumb} />

<!-- HERO -->
<section class={`relative overflow-hidden bg-gradient-to-br ${colorMap[category.color]} text-white`}>
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="absolute -right-10 -top-10 h-96 w-96" viewBox="0 0 200 200">
      <rect x="20" y="20" width="160" height="160" fill="none" stroke="white" stroke-width="1" transform="rotate(15 100 100)"/>
      <rect x="40" y="40" width="120" height="120" fill="none" stroke="white" stroke-width="1" transform="rotate(30 100 100)"/>
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-20">
    <nav class="flex items-center gap-2 text-xs text-white/80 mb-6">
      <a href={`${base}/`} class="hover:text-white">{locale === "de" ? "Start" : "Home"}</a>
      <span>›</span>
      <a href={`${base}/kategorien/`} class="hover:text-white">{locale === "de" ? "Kategorien" : "Categories"}</a>
      <span>›</span>
      <span class="text-white">{category.name[locale]}</span>
    </nav>

    <div class="flex items-center gap-3 mb-5">
      <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 backdrop-blur-sm border border-white/20 text-3xl font-bold">
        {category.icon}
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 backdrop-blur-sm border border-white/20 px-3 py-1 text-[11px] font-bold uppercase tracking-widest">
        {category.priceHint[locale]}
      </span>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-balance mb-6 leading-[1.05]">
      {category.name[locale]} {locale === "de" ? "in Berlin" : "in Berlin"}
    </h1>
    <p class="text-lg sm:text-xl text-white/95 leading-relaxed max-w-3xl text-balance">
      {category.intro[locale]}
    </p>
  </div>
</section>

<!-- DESCRIPTION -->
<section class="py-14 sm:py-16">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="prose-balanced">
      <p class="text-lg text-ink-700 leading-relaxed text-balance">
        {category.description[locale]}
      </p>
    </div>
  </div>
</section>

<!-- BEST DISTRICTS -->
{bestDistricts.length > 0 && (
  <section class="py-14 sm:py-16 surface-soft">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-2 block">
          {locale === "de" ? "Wo du sie findest" : "Where to find them"}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 text-balance">
          {locale === "de"
            ? `Beste Bezirke für ${category.shortName[locale]}-Hotels`
            : `Best districts for ${category.shortName[locale].toLowerCase()} hotels`}
        </h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {bestDistricts.map((d) => <DistrictCard district={d} locale={locale} />)}
      </div>
    </div>
  </section>
)}

<!-- HOTELS -->
{hotelsInCategory.length > 0 && (
  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-2 block">
          {locale === "de" ? "Unsere Auswahl" : "Our selection"}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 text-balance">
          {locale === "de" ? `Die besten ${category.name.de}` : `The best ${category.name.en.toLowerCase()}`}
        </h2>
        <p class="text-ink-600 leading-relaxed mt-3">
          {locale === "de"
            ? `${hotelsInCategory.length} ausgewählte Hotels in der Kategorie ${category.shortName.de}.`
            : `${hotelsInCategory.length} curated hotels in the ${category.shortName.en} category.`}
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {hotelsInCategory.map((h) => <HotelCard hotel={h} locale={locale} />)}
      </div>
    </div>
  </section>
)}

<!-- RELATED ARTICLES -->
{relatedArticles.length > 0 && (
  <section class="py-14 sm:py-16 surface-soft">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-2 block">
          {locale === "de" ? "Ratgeber & Guides" : "Guides & articles"}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 text-balance">
          {locale === "de"
            ? `Ratgeber zu ${category.shortName.de}-Hotels`
            : `Guides for ${category.shortName.en.toLowerCase()} hotels`}
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {relatedArticles.map((a) => (
          <a
            href={`/${a.slug}/`}
            class="block rounded-2xl border border-ink-100 bg-white p-5 hover:border-brand-300 hover:shadow-md transition-all"
          >
            <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-2 block">
              {a.kicker}
            </span>
            <h3 class="text-lg font-bold text-ink-900 mb-2 text-balance">{a.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed line-clamp-2">{a.description}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:text-brand-800">
              Weiterlesen →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- OTHER CATEGORIES -->
<section class="py-14 sm:py-16 bg-ink-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">
        {locale === "de" ? "Andere Hotel-Stile entdecken" : "Discover other hotel styles"}
      </h2>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {otherCategories.map((c) => <CategoryCard category={c} locale={locale} />)}
    </div>
  </div>
</section>
