---
/**
 * GuestPostPage — Renderer für die übernommenen Gastbeiträge.
 * Diese Beiträge bleiben unter ihrer EXAKTEN alten URL erhalten und behalten
 * ihren dofollow-Outbound-Link unverändert (bezahlte Backlink-Artikel).
 * Bewusst schlicht gehalten (Prosa, kein Hotel-/Affiliate-Modul), kein noindex.
 */
import type { GuestPost } from "../data/guest-posts";
import { site } from "../data/site";
import JsonLd from "./JsonLd.astro";

type Props = { post: GuestPost };
const { post } = Astro.props;
const url = new URL(`/${post.slug}/`, site.baseUrl).toString();

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Start", item: site.baseUrl + "/" },
    { "@type": "ListItem", position: 2, name: post.title, item: url },
  ],
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.description,
  inLanguage: "de-DE",
  mainEntityOfPage: url,
  ...(post.image ? { image: new URL(post.image.src, site.baseUrl).toString() } : {}),
  datePublished: post.datePublished,
  dateModified: post.dateModified,
  author: { "@type": "Organization", name: site.brand.name, url: site.baseUrl },
  publisher: { "@type": "Organization", name: site.brand.name, url: site.baseUrl },
};
---

<JsonLd data={breadcrumb} />
<JsonLd data={articleSchema} />

<article class="mx-auto max-w-3xl px-4 sm:px-6 py-12 sm:py-16">
  <nav class="flex items-center gap-2 text-xs text-ink-500 mb-6">
    <a href="/" class="hover:text-brand-700">Start</a>
    <span>›</span>
    <span class="text-ink-700">{post.title}</span>
  </nav>

  <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 text-balance mb-6 leading-[1.15]">
    {post.title}
  </h1>

  {post.image && (
    <figure class="mb-8">
      <div class="aspect-[16/9] w-full overflow-hidden rounded-2xl border border-ink-100 bg-ink-50">
        <img
          src={post.image.src}
          alt={post.image.alt}
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
      {post.image.credit && (
        <figcaption class="mt-2 text-xs text-ink-400">{post.image.credit}</figcaption>
      )}
    </figure>
  )}

  <div class="space-y-5 text-ink-700 leading-relaxed text-lg [&_a]:text-brand-700 [&_a]:font-medium [&_a:hover]:underline">
    {post.blocks.map((b) =>
      b.type === "h2" ? (
        <h2 class="text-2xl font-bold tracking-tight text-ink-900 pt-4" set:html={b.html} />
      ) : b.type === "h3" ? (
        <h3 class="text-xl font-semibold text-ink-900 pt-2" set:html={b.html} />
      ) : (
        <p set:html={b.html} />
      ),
    )}
  </div>

  <div class="mt-12 pt-6 border-t border-ink-100">
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 hover:text-brand-800">
      ← Zurück zu About Berlin Hotels
    </a>
  </div>
</article>
