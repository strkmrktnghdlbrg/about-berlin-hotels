---
import type { Category } from "../data/categories";
import type { Locale } from "../data/site";

type Props = { category: Category; locale: Locale };
const { category, locale } = Astro.props;

const base = locale === "de" ? "/kategorien" : "/en/categories";
const slug = locale === "de" ? category.slug : category.slugEn;
const href = `${base}/${slug}/`;

const colorMap: Record<Category["color"], string> = {
  navy: "from-brand-800 to-brand-600",
  azure: "from-brand-600 to-brand-400",
  teal: "from-accent-teal to-brand-500",
  indigo: "from-brand-700 to-brand-500",
  sky: "from-brand-500 to-brand-300",
  amber: "from-accent-amber to-brand-400",
};
---

<a
  href={href}
  class="group relative block rounded-2xl border border-ink-100 bg-white p-6 transition-all hover:border-brand-200 hover:shadow-lg overflow-hidden"
>
  <div class={`absolute -right-8 -top-8 h-32 w-32 rounded-full bg-gradient-to-br ${colorMap[category.color]} opacity-10 transition-all group-hover:scale-125`}></div>

  <div class="relative">
    <div class="flex items-center gap-2 mb-2">
      <span class={`inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br ${colorMap[category.color]} text-white text-lg font-bold`}>
        {category.icon}
      </span>
      <h3 class="text-base font-bold text-ink-900 group-hover:text-brand-700 transition-colors">
        {category.name[locale]}
      </h3>
    </div>

    <p class="text-sm text-ink-600 leading-relaxed mb-3 line-clamp-2">
      {category.intro[locale]}
    </p>

    <div class="flex items-center justify-between text-xs">
      <span class="font-semibold text-brand-700">{category.priceHint[locale]}</span>
      <span class="text-ink-500">{category.hotelCount} {locale === "de" ? "Hotels" : "hotels"}</span>
    </div>
  </div>
</a>
