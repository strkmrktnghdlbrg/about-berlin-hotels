---
import { site, type Locale, localePrefix } from "../data/site";
import { t, tr } from "../data/i18n";

type Props = { locale: Locale };
const { locale } = Astro.props;
const base = localePrefix(locale);
const year = new Date().getFullYear();
---

<footer class="mt-20 bg-ink-900 text-ink-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-14">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl gradient-spree text-white">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-5 w-5">
              <path d="M3 21V10l9-7 9 7v11" />
              <path d="M9 21V13h6v8" />
            </svg>
          </span>
          <span class="text-white text-base font-bold">About Berlin Hotels</span>
        </div>
        <p class="text-sm text-ink-400 max-w-md mb-4">
          {tr(t.footer.aboutBody, locale)}
        </p>
        <p class="text-xs text-ink-500 max-w-md">
          {tr(t.footer.affiliateDisclosure, locale)}
        </p>
      </div>

      <div>
        <h3 class="text-white text-sm font-semibold mb-3">{tr(t.footer.quickLinks, locale)}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={locale === "de" ? "/stadtteile/" : "/en/districts/"} class="hover:text-white">{tr(t.nav.districts, locale)}</a></li>
          <li><a href={locale === "de" ? "/kategorien/" : "/en/categories/"} class="hover:text-white">{tr(t.nav.categories, locale)}</a></li>
          <li><a href={locale === "de" ? "/sehenswuerdigkeiten/" : "/en/attractions/"} class="hover:text-white">{tr(t.nav.attractions, locale)}</a></li>
          <li><a href={locale === "de" ? "/tipps/" : "/en/tips/"} class="hover:text-white">{tr(t.nav.tips, locale)}</a></li>
          {locale === "de" && (
            <li><a href="/parken-flughafen-berlin/" class="hover:text-white">Parken am Flughafen BER</a></li>
          )}
        </ul>
      </div>

      <div>
        <h3 class="text-white text-sm font-semibold mb-3">{tr(t.nav.legal, locale)}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={locale === "de" ? "/ueber-uns/" : "/en/about/"} class="hover:text-white">{locale === "de" ? "Über uns" : "About"}</a></li>
          <li><a href={locale === "de" ? "/impressum/" : "/en/imprint/"} class="hover:text-white">{tr(t.footer.imprint, locale)}</a></li>
          <li><a href={locale === "de" ? "/datenschutz/" : "/en/privacy/"} class="hover:text-white">{tr(t.footer.privacy, locale)}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ink-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-xs text-ink-500">
      <p>© {year} About Berlin Hotels - {tr(t.footer.copyright, locale)}</p>
      <p>{site.baseUrl.replace("https://", "")}</p>
    </div>
  </div>
</footer>
