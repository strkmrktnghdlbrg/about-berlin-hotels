---
import type { Locale } from "../data/site";

type Props = {
  title: string;
  locale: Locale;
};
const { title, locale } = Astro.props;
---

<section class="surface-soft border-b border-ink-100">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-14 sm:py-16">
    <span class="text-xs font-bold text-brand-700 uppercase tracking-widest mb-2 block">
      {locale === "de" ? "Rechtliches" : "Legal"}
    </span>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-balance text-ink-900 leading-[1.05]">
      {title}
    </h1>
  </div>
</section>

<section class="py-14 sm:py-16">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 prose-balanced">
    <slot />
  </div>
</section>

<style is:global>
  .prose-balanced h2 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 700;
    color: var(--color-ink-900);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-balanced h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-ink-900);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-balanced p {
    color: var(--color-ink-700);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-balanced ul {
    list-style: disc;
    padding-left: 1.25rem;
    color: var(--color-ink-700);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-balanced li { margin-bottom: 0.25rem; }
  .prose-balanced a {
    color: var(--color-brand-700);
    text-decoration: underline;
  }
  .prose-balanced strong { color: var(--color-ink-900); }
</style>
